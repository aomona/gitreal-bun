{
  "name": "gitreal-bun",
  "version": "0.1.0",
  "description": "Bun (TypeScript) reimplementation of watany-dev/gitreal CLI tool",
  "type": "module",
  "bin": {
    "gitreal": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "test": "bun test",
    "lint": "bun run --bun tsc --noEmit",
    "build": "bun build --compile --target=bun src/index.ts --outfile dist/gitreal"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
